# .env.example
# Copy to .env and fill the values before running the app.
# Secrets should NOT be committed to version control. Use .gitignore to exclude your real .env.

# ------- Streamlit / App -------
# Optional: port to run Streamlit on (default 8501/8502)
STREAMLIT_SERVER_PORT=8502

# Debug / logging
LOG_LEVEL=INFO

# ------- RAG / Vector DB (Marvin) -------
# Directory where Chroma (or other vector DB) will persist data (if using local Chroma)
CHROMA_DIR=./chroma_db

# Optional: number of retrieved docs used by RAG
RAG_TOP_K=3

# ------- Azure OpenAI / Foundry (use if you have Azure-hosted model) -------
# If you use Azure Foundry/OpenAI-compatible endpoint, set these values.
# AZURE_OPENAI_ENDPOINT example: https://<your-resource-name>.openai.azure.com
AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_KEY: primary key for the Azure OpenAI resource
AZURE_OPENAI_KEY=
# AZURE_OPENAI_DEPLOYMENT: deployment name or model alias you created in Azure
AZURE_OPENAI_DEPLOYMENT=

# ------- OpenAI (optional fallback) -------
# Set if you want to use OpenAI directly instead of Azure
OPENAI_API_KEY=

# ------- HuggingFace (optional) -------
# If you use HuggingFace Inference or HF embeddings
HUGGINGFACE_API_TOKEN=

# ------- PDF / Indexing (Marvin) -------
# Path or base URL where indexed PDFs are stored / served from.
# Example: http://pdf-server.internal/files/ or ./data/pdfs
PDF_BASE_URL=
# Optional: local folder where raw PDFs live (used for indexing)
PDF_SOURCE_DIR=./data

# ------- Other / Tuning -------
# LLM temperature (if used by your chain)
LLM_TEMPERATURE=0.0

# NOTE
# 1) Copy this file to ".env" and fill values.
# 2) For local development you can use 'export $(cat .env | xargs)' or a dotenv loader.
# 3) Do NOT commit your real .env to git. Add .env to .gitignore.
# 4) Tobias will need AZURE_* or OPENAI_* and Marvin must ensure CHROMA_DIR contains the persisted index and docs contain metadata: pdf_url, source, page.
