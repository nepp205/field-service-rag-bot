# ── Request Handler: Azure OpenAI ────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT="https://atc-fsm-bot-resource.openai.azure.com/"
AZURE_OPENAI_API_KEY="KEy"
AZURE_OPENAI_DEPLOYMENT="gpt-4o-mini-main"

# ── Context Handler: Qdrant vector DB ────────────────────────────────────────
QDRANT_URL="https://512bf099-ef76-4b8d-bbb0-81c64346546e.eu-central-1-0.aws.cloud.qdrant.io"
QDRANT_API_KEY="key"

# ── Context Handler: HuggingFace token (for embedding model) ─────────────────
HF_TOKEN="token"

# ── Shared: auth token between request-handler and context-handler ───────────
# Must match the WEBSERVER_TOKEN the context-handler validates on each request.
WEBSERVER_TOKEN="token"

# ── Request Handler → Context Handler wiring ─────────────────────────────────
# Internal Docker DNS URL – uses the service name from docker-compose.yml.
# Do NOT change this value unless you rename the service.
CONTEXT_HANDLER_URL="http://context-handler:5000/context"
# Must be the same secret as WEBSERVER_TOKEN above.
CONTEXT_HANDLER_TOKEN="token"
