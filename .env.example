# Copy this file to .env and fill in your values.
# .env is git-ignored and must NEVER be committed.
#
# This single file covers both microservices when running via the root
# docker-compose.yml.  Fill in ALL values before running:
#
#   cp .env.example .env
#   docker compose up --build

# ── Request Handler: Azure OpenAI ────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_DEPLOYMENT=<your-deployment-name>

# ── Context Handler: Qdrant vector DB ────────────────────────────────────────
QDRANT_URL=https://<your-cluster>.qdrant.io
QDRANT_API_KEY=<your-qdrant-api-key>

# ── Context Handler: HuggingFace token (for embedding model) ─────────────────
HF_TOKEN=<your-hf-token>

# ── Shared: auth token between request-handler and context-handler ───────────
# Must match the WEBSERVER_TOKEN the context-handler validates on each request.
WEBSERVER_TOKEN=<choose-a-strong-random-token>
